---
import Layout from '../layouts/Layout.astro';
import { getGameweeks } from '../api/gameweeks';
import { getCaptainPicks } from '../api/decisions';
import { getPlayers } from '../api/players';
import { POSITIONS, formatCost } from '../lib/types';

const gameweeks = await getGameweeks();
const currentGW = gameweeks.find(gw => gw.is_current);
const nextGW = gameweeks.find(gw => gw.is_next);
const captains = await getCaptainPicks(5);
const topForm = await getPlayers({ sort_by: 'form_points', limit: 5 });
---

<Layout title="Dashboard">
  <!-- GW Status -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <div class="bg-fpl-card rounded-lg p-5 border border-gray-700">
      <div class="text-gray-400 text-sm mb-1">Current Gameweek</div>
      <div class="text-2xl font-bold text-white">{currentGW?.name ?? 'N/A'}</div>
      {currentGW?.average_entry_score && (
        <div class="text-sm text-gray-400 mt-1">Avg score: {currentGW.average_entry_score}</div>
      )}
    </div>
    <div class="bg-fpl-card rounded-lg p-5 border border-gray-700">
      <div class="text-gray-400 text-sm mb-1">Next Deadline</div>
      <div class="text-2xl font-bold text-fpl-green">
        {nextGW ? new Date(nextGW.deadline_time).toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) : 'N/A'}
      </div>
      <div class="text-sm text-gray-400 mt-1">{nextGW?.name}</div>
    </div>
    <div class="bg-fpl-card rounded-lg p-5 border border-gray-700">
      <div class="text-gray-400 text-sm mb-1">Season Progress</div>
      <div class="text-2xl font-bold text-white">{gameweeks.filter(gw => gw.is_finished).length}/38</div>
      <div class="w-full bg-gray-700 rounded-full h-2 mt-2">
        <div class="bg-fpl-green h-2 rounded-full" style={`width: ${(gameweeks.filter(gw => gw.is_finished).length / 38) * 100}%`}></div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Top Captain Picks -->
    <div class="bg-fpl-card rounded-lg border border-gray-700">
      <div class="px-5 py-3 border-b border-gray-700 flex justify-between items-center">
        <h2 class="font-semibold text-white">Top Captain Picks</h2>
        <a href="/decisions/captain" class="text-fpl-cyan text-sm hover:underline">View all</a>
      </div>
      <div class="divide-y divide-gray-800">
        {captains.map((c, i) => (
          <div class="px-5 py-3 flex items-center gap-3">
            <span class="text-lg font-bold text-gray-500 w-6">{i + 1}</span>
            <div class="flex-1">
              <a href={`/players/${c.player_id}`} class="text-white font-medium hover:text-fpl-cyan">{c.web_name}</a>
              <span class="text-gray-400 text-sm ml-2">{c.team_short_name} · {POSITIONS[c.position]}</span>
            </div>
            <div class="text-right">
              <div class="text-fpl-green font-medium">Ceiling: {c.ceiling_score}</div>
              <div class="text-gray-400 text-xs">Form: {c.form_points} pts</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Top Form Players -->
    <div class="bg-fpl-card rounded-lg border border-gray-700">
      <div class="px-5 py-3 border-b border-gray-700 flex justify-between items-center">
        <h2 class="font-semibold text-white">Hot Form (Last 6 GWs)</h2>
        <a href="/players" class="text-fpl-cyan text-sm hover:underline">View all</a>
      </div>
      <div class="divide-y divide-gray-800">
        {topForm.map((p, i) => (
          <div class="px-5 py-3 flex items-center gap-3">
            <span class="text-lg font-bold text-gray-500 w-6">{i + 1}</span>
            <div class="flex-1">
              <a href={`/players/${p.id}`} class="text-white font-medium hover:text-fpl-cyan">{p.web_name}</a>
              <span class="text-gray-400 text-sm ml-2">{p.team_short_name} · {formatCost(p.now_cost)}</span>
            </div>
            <div class="text-right">
              <div class="text-fpl-green font-medium">{p.form_points} pts</div>
              <div class="text-gray-400 text-xs">{p.pts_per_game} pts/g</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>
