---
interface Props {
  label: string;
  value: string | number;
  subtext?: string;
  help?: string;
  accent?: string;
}
const { label, value, subtext, help, accent = 'text-white' } = Astro.props;
---

<div class="flex flex-col gap-1">
  <span class="stat-label flex items-center gap-1">
    {label}
    {help && (
      <span class="relative group/stat">
        <span class="w-3 h-3 rounded-full bg-gray-600/40 text-gray-500 text-[8px] font-bold inline-flex items-center justify-center cursor-help">?</span>
        <span class="absolute bottom-full left-0 mb-1.5 w-56 p-2 rounded-lg bg-gray-900/95 border border-gray-600 text-[11px] text-gray-200 leading-relaxed shadow-xl opacity-0 invisible group-hover/stat:opacity-100 group-hover/stat:visible transition-all duration-150 z-50 normal-case tracking-normal font-normal">
          {help}
        </span>
      </span>
    )}
  </span>
  <span class:list={['stat-value', accent]}>{value}</span>
  {subtext && <span class="text-[11px] text-gray-400 leading-tight">{subtext}</span>}
</div>
