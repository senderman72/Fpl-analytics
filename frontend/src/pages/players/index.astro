---
import Layout from '../../layouts/Layout.astro';
import PlayerTable from '../../components/PlayerTable';
import { getPlayers } from '../../api/players';

const players = await getPlayers({ sort_by: 'form_points', limit: 100 });
---

<Layout title="Players">
  <h1 class="page-title mb-1">Player Stats</h1>
  <p class="text-gray-400 text-sm mb-5">Compare stats across all {players.length}+ Premier League players</p>
  <PlayerTable client:load initial={players} />
</Layout>
