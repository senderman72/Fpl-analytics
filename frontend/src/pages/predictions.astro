---
import Layout from '../layouts/Layout.astro';
import { getGameweeks } from '../api/gameweeks';
import { getPredictions } from '../api/predictions';
import { POSITIONS, formatCost, POSITION_COLORS } from '../lib/types';

const gameweeks = await getGameweeks();
const nextGW = gameweeks.find(gw => gw.is_next);
const gwId = nextGW?.id ?? gameweeks.filter(gw => gw.is_finished).length + 1;

const predictions = await getPredictions(gwId, { limit: 50 });
---

<Layout title="Predictions">
  <h1 class="text-2xl font-bold text-white mb-1">Points Predictions</h1>
  <p class="text-gray-400 mb-6">Predicted points for {nextGW?.name ?? `Gameweek ${gwId}`} — Ridge regression model</p>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-left text-gray-400 border-b border-gray-700">
          <th class="py-2 px-2">#</th>
          <th class="py-2 px-2">Player</th>
          <th class="py-2 px-2">Team</th>
          <th class="py-2 px-2">Pos</th>
          <th class="py-2 px-2 text-right">Price</th>
          <th class="py-2 px-2 text-right">Predicted Pts</th>
        </tr>
      </thead>
      <tbody>
        {predictions.map((p, i) => (
          <tr class="border-b border-gray-800 hover:bg-fpl-card/50">
            <td class="py-2 px-2 text-gray-500">{i + 1}</td>
            <td class="py-2 px-2">
              <a href={`/players/${p.player_id}`} class="text-fpl-cyan hover:underline font-medium">{p.web_name}</a>
            </td>
            <td class="py-2 px-2 text-gray-400">{p.team_short_name}</td>
            <td class="py-2 px-2">
              <span class="text-xs px-1.5 py-0.5 rounded" style={`color: ${POSITION_COLORS[p.position]}; background: ${POSITION_COLORS[p.position]}20`}>
                {POSITIONS[p.position]}
              </span>
            </td>
            <td class="py-2 px-2 text-right">{formatCost(p.now_cost)}</td>
            <td class="py-2 px-2 text-right">
              <span class="text-lg font-bold text-fpl-green">{p.predicted_points}</span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Layout>
