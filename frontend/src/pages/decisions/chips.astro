---
import Layout from '../../layouts/Layout.astro';
import { getChipAdvice } from '../../api/decisions';

const chips = await getChipAdvice();
---

<Layout title="Chip Advisor">
  <h1 class="text-2xl font-bold text-white mb-4">Chip Advisor</h1>
  <p class="text-gray-400 mb-6">Upcoming gameweeks with DGW/BGW signals for chip timing</p>

  <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-3">
    {chips.map((gw) => (
      <div class:list={[
        'rounded-lg p-4 border text-center',
        gw.is_double ? 'bg-fpl-green/10 border-fpl-green/40' :
        gw.is_blank ? 'bg-fpl-pink/10 border-fpl-pink/40' :
        'bg-fpl-card border-gray-700',
      ]}>
        <div class="text-sm font-medium text-white">{gw.name}</div>
        {gw.is_double && (
          <div class="mt-2">
            <span class="text-xs font-bold text-fpl-green bg-fpl-green/20 px-2 py-0.5 rounded">DGW</span>
          </div>
        )}
        {gw.is_blank && (
          <div class="mt-2">
            <span class="text-xs font-bold text-fpl-pink bg-fpl-pink/20 px-2 py-0.5 rounded">BGW</span>
          </div>
        )}
        {gw.recommendation && (
          <div class="mt-2 text-xs text-gray-300">{gw.recommendation}</div>
        )}
        {!gw.is_double && !gw.is_blank && (
          <div class="mt-2 text-xs text-gray-500">Normal</div>
        )}
      </div>
    ))}
  </div>
</Layout>
