---
import { buildCanonical } from '../lib/seo';
import CookieConsent from '../components/CookieConsent';
import InstallPrompt from '../components/InstallPrompt';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const {
  title,
  description = 'FPL Analytics — data-driven Fantasy Premier League tools: captain picks, transfer advice, points predictions, and fixture analysis.',
  ogImage = '/og-default.png',
} = Astro.props;
const canonicalUrl = buildCanonical(Astro.url.pathname);
const fullTitle = `${title} | FPL Analytics`;
const currentPath = Astro.url.pathname;

const topNav = [
  { href: '/', label: 'Dashboard' },
  { href: '/my-team', label: 'My Team' },
  { href: '/live', label: 'Live' },
  { href: '/players', label: 'Players' },
  { href: '/fixtures', label: 'Fixtures' },
  { href: '/predictions', label: 'Predictions' },
];

const toolsNav = [
  { href: '/decisions/buy-sell', label: 'Transfers' },
  { href: '/decisions/prices', label: 'Prices' },
  { href: '/decisions/captain', label: 'Captain' },
  { href: '/decisions/chips', label: 'Chips' },
];

const toolsActive = currentPath.startsWith('/decisions');

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#37003c" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={buildCanonical(ogImage)} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="FPL Analytics" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={buildCanonical(ogImage)} />
    <title>{fullTitle}</title>
    <!-- GA4 with Consent Mode v2 — analytics blocked until user accepts -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
      });
      if (localStorage.getItem('cookie_consent') === 'accepted') {
        gtag('consent', 'update', { analytics_storage: 'granted' });
      }
      gtag('js', new Date());
      gtag('config', 'G-L6SSDG9F6S');
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-L6SSDG9F6S"></script>
    <style is:global>
      html { scroll-behavior: smooth; overflow-x: hidden; }
      body { overflow-x: hidden; }
      @media (display-mode: standalone) {
        .safe-top { padding-top: env(safe-area-inset-top); }
        .safe-bottom { padding-bottom: env(safe-area-inset-bottom); }
      }
    </style>
  </head>
  <body class="bg-fpl-dark text-gray-200 font-sans min-h-screen flex flex-col text-sm md:text-base">
    <!-- Top Nav -->
    <nav class="sticky top-0 z-50 bg-fpl-purple/95 backdrop-blur-md border-b border-fpl-green/10 safe-top">
      <div class="max-w-7xl mx-auto px-4 py-2.5 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 shrink-0">
          <span class="text-fpl-green font-extrabold text-lg tracking-tight">FPL</span>
          <span class="text-white font-semibold text-lg hidden sm:inline">Analytics</span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-1">
          {topNav.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'px-3 py-1.5 rounded-lg text-sm font-medium transition-all duration-150',
                isActive(href)
                  ? 'bg-fpl-green/15 text-fpl-green border-b-2 border-fpl-green'
                  : 'text-gray-300 hover:text-white hover:bg-white/5',
              ]}
            >
              {label}
            </a>
          ))}

          <!-- Tools dropdown -->
          <div class="relative group">
            <button
              class:list={[
                'px-3 py-1.5 rounded-lg text-sm font-medium transition-all duration-150 flex items-center gap-1',
                toolsActive
                  ? 'bg-fpl-green/15 text-fpl-green border-b-2 border-fpl-green'
                  : 'text-gray-300 hover:text-white hover:bg-white/5',
              ]}
            >
              Tools
              <svg class="w-3.5 h-3.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute right-0 top-full mt-1 w-44 bg-fpl-card border border-gray-700 rounded-xl shadow-xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
              {toolsNav.map(({ href, label }) => (
                <a
                  href={href}
                  class:list={[
                    'block px-4 py-2.5 text-sm transition-colors',
                    isActive(href) ? 'text-fpl-green bg-fpl-green/10' : 'text-gray-300 hover:text-white hover:bg-white/5',
                  ]}
                >
                  {label}
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Mobile: just logo, nav is in bottom tab bar -->
        <div class="md:hidden" />
      </div>
    </nav>

    <!-- Main -->
    <main class="flex-1 max-w-7xl w-full mx-auto px-4 py-6 pb-24 md:pb-6">
      <slot />
    </main>

    <!-- Footer (desktop only) -->
    <footer class="hidden md:block border-t border-gray-800 py-4 mt-auto">
      <div class="max-w-7xl mx-auto px-4 flex flex-col sm:flex-row justify-between items-center gap-2 text-xs text-gray-400">
        <span>FPL Analytics — data from the official FPL API & Understat</span>
        <span>Built with FastAPI, Astro & SolidJS</span>
      </div>
    </footer>

    <!-- Mobile Bottom Tab Bar -->
    <nav class="md:hidden fixed bottom-0 inset-x-0 z-50 bg-fpl-card/95 backdrop-blur-md border-t border-gray-700/50 safe-bottom">
      <div class="flex items-stretch justify-around">
        <!-- Home -->
        <a href="/" class:list={['flex flex-col items-center justify-center py-2 px-1 flex-1 min-h-[56px] transition-colors', isActive('/') && currentPath === '/' ? 'text-fpl-green' : 'text-gray-400']}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
          <span class="text-[11px] mt-0.5">Home</span>
        </a>

        <!-- My Team -->
        <a href="/my-team" class:list={['flex flex-col items-center justify-center py-2 px-1 flex-1 min-h-[56px] transition-colors', isActive('/my-team') ? 'text-fpl-green' : 'text-gray-400']}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          <span class="text-[11px] mt-0.5">My Team</span>
        </a>

        <!-- Players -->
        <a href="/players" class:list={['flex flex-col items-center justify-center py-2 px-1 flex-1 min-h-[56px] transition-colors', isActive('/players') ? 'text-fpl-green' : 'text-gray-400']}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          <span class="text-[11px] mt-0.5">Players</span>
        </a>

        <!-- Tools -->
        <details class="flex-1 relative">
          <summary class:list={['flex flex-col items-center justify-center py-2 px-1 min-h-[56px] transition-colors cursor-pointer list-none', toolsActive ? 'text-fpl-green' : 'text-gray-400']}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span class="text-[11px] mt-0.5">Tools</span>
          </summary>
          <div class="absolute bottom-full mb-2 left-1/2 -translate-x-1/2 w-48 bg-fpl-card border border-gray-700 rounded-xl shadow-xl py-2 z-50">
            {toolsNav.map(({ href, label }) => (
              <a
                href={href}
                class:list={[
                  'block px-4 py-3 text-sm transition-colors',
                  isActive(href) ? 'text-fpl-green bg-fpl-green/10' : 'text-gray-300 hover:text-white hover:bg-white/5',
                ]}
              >
                {label}
              </a>
            ))}
          </div>
        </details>

        <!-- More -->
        <details class="flex-1 relative">
          <summary class="flex flex-col items-center justify-center py-2 px-1 min-h-[56px] transition-colors cursor-pointer list-none text-gray-400">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" /></svg>
            <span class="text-[11px] mt-0.5">More</span>
          </summary>
          <div class="absolute bottom-full mb-2 right-0 w-48 bg-fpl-card border border-gray-700 rounded-xl shadow-xl py-2 z-50">
            <a href="/live" class:list={['block px-4 py-3 text-sm transition-colors', isActive('/live') ? 'text-fpl-green bg-fpl-green/10' : 'text-gray-300 hover:text-white hover:bg-white/5']}>Live</a>
            <a href="/fixtures" class:list={['block px-4 py-3 text-sm transition-colors', isActive('/fixtures') ? 'text-fpl-green bg-fpl-green/10' : 'text-gray-300 hover:text-white hover:bg-white/5']}>Fixtures</a>
            <a href="/predictions" class:list={['block px-4 py-3 text-sm transition-colors', isActive('/predictions') ? 'text-fpl-green bg-fpl-green/10' : 'text-gray-300 hover:text-white hover:bg-white/5']}>Predictions</a>
          </div>
        </details>
      </div>
    </nav>
    <InstallPrompt client:idle />
    <CookieConsent client:idle />
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }
    </script>
  </body>
</html>
