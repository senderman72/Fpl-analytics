---
interface Props {
  text: string;
}
const { text } = Astro.props;
---

<span class="inline-flex items-center group/tip" style="position: relative; z-index: 60;">
  <slot />
  <button
    type="button"
    class="ml-1 w-4 h-4 rounded-full bg-gray-600/40 text-gray-400 text-[9px] font-bold inline-flex items-center justify-center cursor-help shrink-0 hover:bg-gray-500/40 hover:text-gray-300 transition-colors focus:outline-none focus:ring-1 focus:ring-fpl-cyan"
    aria-label="More info"
  >?</button>
  <span class="absolute top-full left-0 mt-1 w-72 p-3 rounded-lg bg-gray-900 border border-gray-600 text-xs text-gray-200 leading-relaxed shadow-2xl opacity-0 invisible group-hover/tip:opacity-100 group-hover/tip:visible focus-within:opacity-100 focus-within:visible transition-all duration-150" style="z-index: 9999; position: absolute;">
    {text}
  </span>
</span>
