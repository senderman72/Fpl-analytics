---
import Layout from '../layouts/Layout.astro';
import JsonLd from '../components/JsonLd.astro';
import { websiteJsonLd, webAppJsonLd } from '../lib/seo';
import DeadlineCountdown from '../components/DeadlineCountdown';
import HeroCard from '../components/HeroCard.astro';
import PositionBadge from '../components/PositionBadge.astro';
import Tooltip from '../components/Tooltip.astro';
import { getGameweeks } from '../api/gameweeks';
import { getBuyCandidates, getCaptainPicks, getDifferentials } from '../api/decisions';
import { getPlayers } from '../api/players';
import { POSITIONS, formatCost } from '../lib/types';
import { STAT_HELP } from '../lib/explanations';
import { slugify } from '../lib/seo';

const gameweeks = await getGameweeks();
const currentGW = gameweeks.find(gw => gw.is_current);
const nextGW = gameweeks.find(gw => gw.is_next);
const finishedCount = gameweeks.filter(gw => gw.is_finished).length;

const [captains, buys, trending, differentials] = await Promise.all([
  getCaptainPicks(5),
  getBuyCandidates({ limit: 3 }),
  getPlayers({ sort_by: 'form_points', limit: 10 }),
  getDifferentials({ limit: 5 }),
]);
const trendingSorted = [...trending].sort((a, b) => (b.transfers_in_event ?? 0) - (a.transfers_in_event ?? 0)).slice(0, 5);

const topCaptain = captains[0];

const quickLinks = [
  { href: '/decisions/buy-sell', label: 'Transfers', desc: 'Find your next move', color: 'border-fpl-green' },
  { href: '/decisions/captain', label: 'Captain', desc: 'Pick your armband', color: 'border-fpl-cyan' },
  { href: '/decisions/chips', label: 'Chips', desc: 'Time your chips right', color: 'border-fpl-pink' },
  { href: '/predictions', label: 'Predictions', desc: 'Model-predicted points', color: 'border-fpl-gold' },
];
---

<Layout title="Dashboard" description="FPL Analytics dashboard — deadline countdown, captain picks, best transfers, trending players, and differentials for Fantasy Premier League.">
  <JsonLd schema={websiteJsonLd()} />
  <JsonLd schema={webAppJsonLd()} />
  <!-- Hero: Deadline + Quick Actions -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-8">
    <div class="lg:col-span-2 relative rounded-2xl overflow-hidden">
      <!-- Background image -->
      <picture>
        <source srcset="/pl-mobile.webp" media="(max-width: 640px)" width="640" height="427" />
        <img src="/pl.webp" alt="" class="absolute inset-0 w-full h-full object-cover object-center" fetchpriority="high" width="1200" height="800" decoding="async" />
      </picture>
      <div class="absolute inset-0 bg-fpl-dark/75 backdrop-blur-[2px]"></div>

      <!-- Content over image -->
      <div class="relative z-10 p-6">
        <!-- GW info row at top -->
        <div class="flex justify-between items-start mb-5">
          {currentGW && (
            <div>
              <div class="text-gray-300 text-xs uppercase tracking-wider mb-1">Current</div>
              <div class="text-white font-bold">{currentGW.name}</div>
              {currentGW.average_entry_score && (
                <div class="text-gray-300 text-sm">Avg: {currentGW.average_entry_score} pts</div>
              )}
            </div>
          )}
          <div class="text-right">
            <div class="text-gray-300 text-xs uppercase tracking-wider mb-1">Next Deadline</div>
            <div class="text-white font-semibold">{nextGW?.name ?? 'Season Complete'}</div>
          </div>
        </div>

        <!-- Countdown -->
        {nextGW && <DeadlineCountdown client:idle deadline={nextGW.deadline_time} />}

        <!-- Season progress -->
        <div class="mt-5 pt-4 border-t border-white/10">
          <div class="flex justify-between text-xs text-gray-300 mb-1.5">
            <span>Season Progress</span>
            <span>{finishedCount}/38 gameweeks</span>
          </div>
          <div class="w-full bg-white/10 rounded-full h-1.5">
            <div class="bg-fpl-green h-1.5 rounded-full transition-all" style={`width: ${(finishedCount / 38) * 100}%`}></div>
          </div>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-2">
      {quickLinks.map(({ href, label, desc, color }) => (
        <a href={href} class:list={['card-hover p-4 border-l-3 flex items-center gap-3 group', color]}>
          <div class="flex-1">
            <div class="text-white font-semibold group-hover:text-fpl-green transition-colors">{label}</div>
            <div class="text-xs text-gray-400">{desc}</div>
          </div>
          <svg class="w-4 h-4 text-gray-400 group-hover:text-fpl-green transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      ))}
    </div>
  </div>

  <!-- Captain Recommendation Banner -->
  {topCaptain && (
    <a href="/decisions/captain" class="block card border-l-3 border-fpl-gold p-5 mb-6 bg-gradient-to-r from-fpl-gold/5 to-transparent hover:from-fpl-gold/10 transition-colors">
      <div class="flex items-center gap-1 text-fpl-gold text-xs font-bold uppercase tracking-wider mb-1">
        <span>Captain Pick of the Week</span>
      </div>
      <div class="flex items-center gap-3">
        <img src={topCaptain.shirt_url || ''} alt="" class="w-10 h-10 shrink-0 object-contain" width="110" height="140" loading="lazy" />
        <span class="text-xl font-extrabold text-white">{topCaptain.web_name}</span>
        <span class="text-gray-400">{topCaptain.team_short_name}</span>
        <PositionBadge position={topCaptain.position} />
      </div>
      <div class="text-sm text-gray-300 mt-1">{topCaptain.recommendation}</div>
    </a>
  )}

  <!-- Action Cards: Best Buys + Trending + Differentials -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Best Transfers In -->
    <div class="card">
      <div class="px-5 py-3 border-b border-gray-700/60 flex justify-between items-center">
        <Tooltip text="Players ranked by attacking stats, value, form, and fixture difficulty. These are the best options to bring into your squad right now."><h2 class="section-title">Best Transfers In</h2></Tooltip>
        <a href="/decisions/buy-sell" class="link-cyan text-xs">View all</a>
      </div>
      <div class="divide-y divide-gray-800/60">
        {buys.map((b, i) => (
          <a href={`/players/${slugify(b.player_id, b.first_name, b.second_name)}`} class="px-5 py-3 block hover:bg-white/3 transition-colors">
            <div class="flex items-center gap-3">
              <span class:list={[
                'w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold shrink-0',
                i === 0 ? 'bg-fpl-green/15 text-fpl-green' : 'bg-gray-700/50 text-gray-400',
              ]}>{i + 1}</span>
              <img src={b.shirt_url || ''} alt="" class="w-9 h-9 shrink-0 object-contain" width="110" height="140" loading="lazy" />
              <div class="flex-1 min-w-0">
                <div class="text-white font-medium truncate">{b.web_name} <span class="text-gray-400 text-xs">{b.team_short_name}</span></div>
                <div class="text-xs text-gray-400">{formatCost(b.now_cost)} · {b.selected_by_percent}% owned</div>
              </div>
              <div class="text-right shrink-0">
                <div class="text-fpl-green font-bold text-sm">{b.form_points} pts</div>
              <div class="text-[11px] text-gray-400">form (6 GW)</div>
              </div>
            </div>
            <div class="text-xs text-gray-400 mt-1 ml-10">{b.recommendation}</div>
          </a>
        ))}
      </div>
    </div>

    <!-- Trending (most transferred in) -->
    <div class="card">
      <div class="px-5 py-3 border-b border-gray-700/60 flex justify-between items-center">
        <Tooltip text={STAT_HELP.transfers_in}><h2 class="section-title">Trending</h2></Tooltip>
        <span class="text-xs text-gray-400">Most transferred in</span>
      </div>
      <div class="divide-y divide-gray-800/60">
        {trendingSorted.map((p) => {
          const netTransfers = (p.transfers_in_event ?? 0) - (p.transfers_out_event ?? 0);
          return (
            <a href={`/players/${slugify(p.id, p.first_name, p.second_name)}`} class="px-5 py-3 flex items-center gap-3 hover:bg-white/3 transition-colors">
              <img src={p.shirt_url || ''} alt="" class="w-9 h-9 shrink-0 object-contain" width="110" height="140" loading="lazy" />
              <div class="flex-1 min-w-0">
                <div class="text-white font-medium truncate">{p.web_name} <span class="text-gray-400 text-xs">{p.team_short_name}</span></div>
                <div class="text-xs text-gray-400">{formatCost(p.now_cost)} · {p.selected_by_percent}% owned</div>
              </div>
              <div class="text-right shrink-0">
                <div class:list={['font-bold text-sm', netTransfers > 0 ? 'text-fpl-green' : 'text-fpl-pink']}>
                  {netTransfers > 0 ? '+' : ''}{(netTransfers / 1000).toFixed(1)}k
                </div>
                <div class="text-[11px] text-gray-400">net transfers</div>
              </div>
            </a>
          );
        })}
      </div>
    </div>

    <!-- Differentials -->
    <div class="card">
      <div class="px-5 py-3 border-b border-gray-700/60 flex justify-between items-center">
        <Tooltip text={STAT_HELP.ownership}><h2 class="section-title">Differentials</h2></Tooltip>
        <span class="text-xs text-gray-400">&lt;5% owned</span>
      </div>
      <div class="divide-y divide-gray-800/60">
        {differentials.map((d) => (
          <a href={`/players/${slugify(d.player_id, d.first_name, d.second_name)}`} class="px-5 py-3 flex items-center gap-3 hover:bg-white/3 transition-colors">
            <img src={d.shirt_url || ''} alt="" class="w-9 h-9 shrink-0 object-contain" width="110" height="140" loading="lazy" />
            <div class="flex-1 min-w-0">
              <div class="text-white font-medium truncate">{d.web_name} <span class="text-gray-400 text-xs">{d.team_short_name}</span></div>
              <div class="text-xs text-gray-400">{formatCost(d.now_cost)} · only {d.selected_by_percent}% owned</div>
            </div>
            <div class="text-right shrink-0">
              <div class="text-fpl-cyan font-bold">{d.xgi_per_90}</div>
              <div class="text-[11px] text-gray-400">xGI/90</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
