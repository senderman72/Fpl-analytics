---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
    <span class="text-8xl font-black text-fpl-green/20 select-none">404</span>
    <h1 class="text-2xl font-bold text-white mt-4">Page Not Found</h1>
    <p class="text-gray-400 mt-2 max-w-md">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="mt-6 inline-flex items-center gap-2 px-5 py-2.5 bg-fpl-green/15 text-fpl-green font-semibold rounded-lg hover:bg-fpl-green/25 transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Back to Dashboard
    </a>
  </div>
</Layout>
