---
import Layout from '../layouts/Layout.astro';
import ShareButtons from '../components/ShareButtons';
import HeroCard from '../components/HeroCard.astro';
import PositionBadge from '../components/PositionBadge.astro';
import { getGameweeks } from '../api/gameweeks';
import { getUpcomingPredictions } from '../api/predictions';
import { POSITIONS, formatCost } from '../lib/types';
import { buildCanonical } from '../lib/seo';

const gameweeks = await getGameweeks();
const predictions = await getUpcomingPredictions({ horizon: 5, limit: 50 });
const top3 = predictions.slice(0, 3);
const rest = predictions.slice(3);

const horizon = predictions[0]?.horizon ?? 5;
const perGwIds = predictions[0]?.predicted_per_gw?.map(g => g.gw_id) ?? [];
---

<Layout title="Predictions" description="FPL predicted points using ridge regression on 22k+ gameweek samples — see who will score the most over the next 5 GWs.">
  <div class="flex items-baseline justify-between mb-6">
    <h1 class="page-title">Points Predictions</h1>
    <span class="text-gray-400 text-sm">Next {horizon} Gameweeks</span>
  </div>
  <div class="mb-6">
    <ShareButtons client:idle url={buildCanonical('/predictions')} text={`FPL predicted points — next ${horizon} GWs`} />
  </div>

  <!-- Methodology Explainer -->
  <div class="card p-5 mb-8 border-l-3 border-fpl-cyan">
    <h2 class="text-white font-bold text-sm mb-2">How predictions work</h2>
    <p class="text-gray-300 text-sm leading-relaxed mb-3">
      Predicted points are generated by a <strong class="text-white">Ridge regression model</strong> trained on all historical gameweek data this season. For each player, the model evaluates their upcoming fixtures individually and sums the expected points across the next {horizon} gameweeks.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1.5 text-xs">
      <div class="flex items-start gap-2">
        <span class="text-fpl-cyan font-bold shrink-0">xGI/90</span>
        <span class="text-gray-400">Expected goals + assists per 90 mins from Understat — measures attacking quality</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-fpl-cyan font-bold shrink-0">Minutes %</span>
        <span class="text-gray-400">Playing time over the last 6 GWs — a proxy for how likely the player is to start</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-fpl-cyan font-bold shrink-0">FDR</span>
        <span class="text-gray-400">Fixture Difficulty Rating (1-5) for each match — easier fixtures yield higher predictions</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-fpl-cyan font-bold shrink-0">Home/Away</span>
        <span class="text-gray-400">Players tend to score more points at home — the model accounts for venue</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-fpl-cyan font-bold shrink-0">BPS avg</span>
        <span class="text-gray-400">Bonus Point System average over last 6 GWs — captures all-round contribution</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-fpl-cyan font-bold shrink-0">DGW</span>
        <span class="text-gray-400">Double Gameweek players have predictions summed across both fixtures</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-fpl-cyan font-bold shrink-0">Set pieces</span>
        <span class="text-gray-400">Penalty and set piece takers get a boost for additional scoring opportunity</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-fpl-cyan font-bold shrink-0">Season xGI</span>
        <span class="text-gray-400">Total expected goal involvements this season — captures longer-term quality</span>
      </div>
    </div>
    <p class="text-gray-400 text-xs mt-3">
      Form data is based on the last 6 gameweeks. Predictions are recalculated after each gameweek when new data is ingested.
    </p>
  </div>

  <!-- Top 3 -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    {top3.map((p, i) => (
      <HeroCard rank={i + 1} accent={i === 0 ? 'border-fpl-gold' : 'border-fpl-green'}>
        <a href={`/players/${p.player_id}`} class="block">
          <div class="flex items-center gap-3 mb-3">
            <img src={p.shirt_url || ''} alt="" class="w-12 h-12 shrink-0 object-contain" width="110" height="140" loading="lazy" />
            <div>
              <div class="flex items-center gap-2">
                <span class="text-white font-bold text-lg">{p.web_name}</span>
                <PositionBadge position={p.position} />
              </div>
              <div class="text-xs text-gray-400">{p.team_short_name} · {formatCost(p.now_cost)}</div>
            </div>
          </div>
          <div class="text-center mb-3">
            <div class="text-4xl font-extrabold text-fpl-green">{p.predicted_points}</div>
            <div class="stat-label mt-1">total predicted pts</div>
          </div>
          {p.predicted_per_gw && p.predicted_per_gw.length > 0 && (
            <div class="flex gap-1.5 justify-center">
              {p.predicted_per_gw.map(gw => (
                <div class="text-center">
                  <div class="text-[11px] text-gray-400">GW{gw.gw_id}</div>
                  <div class="text-xs font-semibold text-gray-300">{gw.predicted_points}</div>
                </div>
              ))}
            </div>
          )}
        </a>
      </HeroCard>
    ))}
  </div>

  <!-- Mobile cards -->
  <div class="md:hidden space-y-2" data-testid="predictions-mobile">
    {rest.map((p, i) => (
      <a href={`/players/${p.player_id}`} class="card p-4 block hover:bg-white/3 transition-colors">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-gray-400 text-xs w-5 text-right shrink-0">{i + 4}</span>
          <img src={p.shirt_url || ''} alt="" class="w-9 h-9 shrink-0 object-contain" width="110" height="140" loading="lazy" />
          <div class="flex-1 min-w-0">
            <div class="text-white font-medium truncate">{p.web_name} <span class="text-gray-400 text-xs">{p.team_short_name}</span></div>
            <div class="text-xs text-gray-400">{formatCost(p.now_cost)} · <PositionBadge position={p.position} /></div>
          </div>
          <div class="text-right shrink-0">
            <div class="text-fpl-green font-bold text-lg">{p.predicted_points}</div>
            <div class="text-[11px] text-gray-400">total pts</div>
          </div>
        </div>
        {p.predicted_per_gw && p.predicted_per_gw.length > 0 && (
          <div class="flex gap-1.5 ml-8">
            {p.predicted_per_gw.map(gw => (
              <div class="text-center flex-1">
                <div class="text-[11px] text-gray-400">GW{gw.gw_id}</div>
                <div class="text-xs font-semibold text-gray-300">{gw.predicted_points}</div>
              </div>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>

  <!-- Desktop table -->
  <div class="hidden md:block card overflow-hidden" data-testid="predictions-desktop">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-fpl-card">
          <tr class="text-left text-gray-400 border-b border-gray-700">
            <th class="py-2.5 px-3 font-medium">#</th>
            <th class="py-2.5 px-3 font-medium">Player</th>
            <th class="py-2.5 px-3 font-medium">Pos</th>
            <th class="py-2.5 px-3 text-right font-medium">Price</th>
            {perGwIds.map(gwId => (
              <th class="py-2.5 px-3 text-right font-medium">GW{gwId}</th>
            ))}
            <th class="py-2.5 px-3 text-right font-medium">Total</th>
          </tr>
        </thead>
        <tbody>
          {rest.map((p, i) => (
            <tr class="border-b border-gray-800/40 hover:bg-white/3 transition-colors">
              <td class="py-2 px-3 text-gray-400">{i + 4}</td>
              <td class="py-2 px-3">
                <a href={`/players/${p.player_id}`} class="flex items-center gap-2">
                  <img src={p.shirt_url || ''} alt="" class="w-7 h-7 shrink-0 object-contain" width="110" height="140" loading="lazy" />
                  <div>
                    <span class="link-cyan font-medium">{p.web_name}</span>
                    <span class="text-gray-400 text-xs ml-1">{p.team_short_name}</span>
                  </div>
                </a>
              </td>
              <td class="py-2 px-3"><PositionBadge position={p.position} /></td>
              <td class="py-2 px-3 text-right tabular-nums">{formatCost(p.now_cost)}</td>
              {p.predicted_per_gw?.map(gw => (
                <td class="py-2 px-3 text-right tabular-nums text-gray-300">{gw.predicted_points}</td>
              ))}
              <td class="py-2 px-3 text-right">
                <span class="text-lg font-bold text-fpl-green tabular-nums">{p.predicted_points}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
  <script is:inline>
    if (typeof window.gtag === 'function') gtag('event', 'prediction_viewed');
  </script>
</Layout>
