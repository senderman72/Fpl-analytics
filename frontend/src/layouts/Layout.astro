---
interface Props {
  title: string;
}
const { title } = Astro.props;
const currentPath = Astro.url.pathname;

const nav = [
  { href: '/', label: 'Dashboard' },
  { href: '/players', label: 'Players' },
  { href: '/decisions/buy-sell', label: 'Buy/Sell' },
  { href: '/decisions/captain', label: 'Captain' },
  { href: '/decisions/chips', label: 'Chips' },
  { href: '/predictions', label: 'Predictions' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | FPL Analytics</title>
  </head>
  <body class="bg-fpl-dark text-gray-100 font-sans min-h-screen">
    <nav class="bg-fpl-purple border-b border-fpl-green/20 px-4 py-3">
      <div class="max-w-7xl mx-auto flex items-center gap-6">
        <a href="/" class="text-fpl-green font-bold text-xl tracking-tight">FPL Analytics</a>
        <div class="flex gap-1">
          {nav.map(({ href, label }) => (
            <a
              href={href}
              class:list={[
                'px-3 py-1.5 rounded text-sm font-medium transition-colors',
                currentPath === href
                  ? 'bg-fpl-green/20 text-fpl-green'
                  : 'text-gray-300 hover:text-white hover:bg-white/5',
              ]}
            >
              {label}
            </a>
          ))}
        </div>
      </div>
    </nav>
    <main class="max-w-7xl mx-auto px-4 py-6">
      <slot />
    </main>
  </body>
</html>
