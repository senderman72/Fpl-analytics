---
interface Props {
  text: string;
}
const { text } = Astro.props;
---

<span class="relative inline-flex items-center group">
  <slot />
  <span class="ml-1 w-3.5 h-3.5 rounded-full bg-gray-600/50 text-gray-400 text-[9px] font-bold inline-flex items-center justify-center cursor-help shrink-0" title={text}>?</span>
  <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-64 p-2.5 rounded-lg bg-gray-900 border border-gray-600 text-xs text-gray-200 leading-relaxed shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50 pointer-events-none">
    {text}
  </span>
</span>
