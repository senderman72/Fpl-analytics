---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Tooltip from '../../components/Tooltip.astro';
import { getChipAdvice } from '../../api/decisions';
import { STAT_HELP } from '../../lib/explanations';

const chips = await getChipAdvice();
const hasRecommendation = chips.some(gw => gw.recommendation);
---

<Layout title="Chip Advisor">
  <Breadcrumb items={[{ label: 'Tools' }, { label: 'Chips' }]} />
  <h1 class="page-title mb-1">Chip Advisor</h1>
  <p class="text-gray-400 text-sm mb-6">Plan when to use your chips for maximum impact</p>

  <!-- Chip explainer for beginners -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-6">
    <div class="card p-4 border-l-3 border-fpl-green">
      <Tooltip text={STAT_HELP.dgw}><div class="font-semibold text-fpl-green text-sm">Double Gameweek (DGW)</div></Tooltip>
      <p class="text-xs text-gray-300 mt-1">A team plays two matches in one week. Their players can score points from both games — ideal for <strong>Bench Boost</strong> (all your bench plays) or <strong>Triple Captain</strong> (3x your captain's points).</p>
    </div>
    <div class="card p-4 border-l-3 border-fpl-pink">
      <Tooltip text={STAT_HELP.bgw}><div class="font-semibold text-fpl-pink text-sm">Blank Gameweek (BGW)</div></Tooltip>
      <p class="text-xs text-gray-300 mt-1">Some teams have no match this week — their players score 0. Use your <strong>Free Hit</strong> chip to pick a whole new squad for just that week.</p>
    </div>
    <div class="card p-4 border-l-3 border-fpl-cyan">
      <div class="font-semibold text-fpl-cyan text-sm">Wildcard</div>
      <p class="text-xs text-gray-300 mt-1">Unlimited free transfers for one week. Best used when your squad needs a major overhaul — often before a run of DGWs.</p>
    </div>
  </div>

  <!-- Alert banner if there's a recommendation -->
  {hasRecommendation && (
    <div class="card border-l-3 border-fpl-green p-4 mb-6 bg-fpl-green/5">
      <div class="font-semibold text-fpl-green text-sm mb-1">Chip Opportunities Detected</div>
      <div class="text-xs text-gray-300">
        {chips.filter(gw => gw.recommendation).map(gw => (
          <span class="mr-3">{gw.name}: {gw.recommendation}</span>
        ))}
      </div>
    </div>
  )}

  <!-- GW Calendar Grid -->
  <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-7 gap-2">
    {chips.map((gw) => (
      <div class:list={[
        'rounded-xl border text-center transition-all',
        gw.is_double ? 'p-4 bg-fpl-green/8 border-fpl-green/30 ring-1 ring-fpl-green/10' :
        gw.is_blank ? 'p-4 bg-fpl-pink/8 border-fpl-pink/30 ring-1 ring-fpl-pink/10' :
        'p-3 bg-fpl-card border-gray-700/40 opacity-60',
      ]}>
        <div class:list={[
          'text-sm font-semibold',
          gw.is_double ? 'text-fpl-green' : gw.is_blank ? 'text-fpl-pink' : 'text-gray-400',
        ]}>
          {gw.name.replace('Gameweek ', 'GW')}
        </div>

        {gw.is_double && (
          <div class="mt-2">
            <span class="text-[11px] font-extrabold text-fpl-green bg-fpl-green/15 px-2.5 py-1 rounded-full">DGW</span>
            <div class="text-[11px] text-gray-300 mt-1.5 leading-tight">BB / TC</div>
          </div>
        )}
        {gw.is_blank && (
          <div class="mt-2">
            <span class="text-[11px] font-extrabold text-fpl-pink bg-fpl-pink/15 px-2.5 py-1 rounded-full">BGW</span>
            <div class="text-[11px] text-gray-300 mt-1.5 leading-tight">Free Hit</div>
          </div>
        )}
        {!gw.is_double && !gw.is_blank && (
          <div class="mt-1 text-[11px] text-gray-600">Normal</div>
        )}
      </div>
    ))}
  </div>
</Layout>
