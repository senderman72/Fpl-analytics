---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import HeroCard from '../../components/HeroCard.astro';
import PositionBadge from '../../components/PositionBadge.astro';
import Tooltip from '../../components/Tooltip.astro';
import ShareButtons from '../../components/ShareButtons';
import { getCaptainPicks } from '../../api/decisions';
import { getGameweeks } from '../../api/gameweeks';
import { POSITIONS, formatCost } from '../../lib/types';
import { STAT_HELP } from '../../lib/explanations';
import { slugify, buildCanonical } from '../../lib/seo';

const picks = await getCaptainPicks(15);
const gameweeks = await getGameweeks();
const nextGW = gameweeks.find(gw => gw.is_next);
const top3 = picks.slice(0, 3);
const rest = picks.slice(3);
---

<Layout title="Captain Picker" description={`${nextGW?.name ?? 'GW'} captain picks ranked by ceiling, form, BPS, and fixture difficulty — FPL Analytics.`}>
  <Breadcrumb items={[{ label: 'Tools' }, { label: 'Captain' }]} />
  <div class="flex items-baseline justify-between mb-6">
    <h1 class="page-title">Captain Picks</h1>
    {nextGW && <span class="text-gray-400 text-sm">{nextGW.name}</span>}
  </div>
  <div class="mb-6">
    <ShareButtons client:idle url={buildCanonical('/decisions/captain')} text={`${nextGW?.name ?? 'GW'} captain picks from FPL Analytics`} />
  </div>

  <!-- Top 3 Hero Cards -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    {top3.map((c, i) => (
      <HeroCard rank={i + 1} accent={i === 0 ? 'border-fpl-gold' : i === 1 ? 'border-gray-400' : 'border-amber-700'}>
        <a href={`/players/${slugify(c.player_id, c.first_name, c.second_name)}`} class="block">
          <div class="flex items-center gap-3 mb-3">
            <img src={c.shirt_url || ''} alt="" class="w-12 h-12 shrink-0 object-contain" width="110" height="140" loading="lazy" />
            <div>
              <div class="flex items-center gap-2">
                <span class="text-white font-bold text-lg">{c.web_name}</span>
                <PositionBadge position={c.position} />
              </div>
              <div class="text-xs text-gray-400">{c.team_short_name} · {formatCost(c.now_cost)}</div>
            </div>
          </div>
          <div class="flex gap-4">
            <div><div class="stat-label">Ceiling (10 GW)</div><div class="text-xl font-extrabold text-fpl-green">{c.ceiling_score}</div></div>
            <div><div class="stat-label">Form (6 GW)</div><div class="text-xl font-extrabold text-white">{c.form_points}</div></div>
            <div><div class="stat-label">BPS Avg</div><div class="text-xl font-extrabold text-white">{c.bps_avg}</div></div>
          </div>
          <div class="flex gap-2 mt-3">
            {c.is_home === true && <span class="text-[11px] font-bold text-emerald-400 bg-emerald-400/10 px-2 py-0.5 rounded-full">HOME</span>}
            {c.is_home === false && <span class="text-[11px] font-bold text-gray-400 bg-gray-400/10 px-2 py-0.5 rounded-full">AWAY</span>}
            {c.is_double_gw && <span class="text-[11px] font-bold text-fpl-pink bg-fpl-pink/10 px-2 py-0.5 rounded-full">DGW</span>}
            {c.is_penalty_taker && <span class="text-[11px] font-bold text-fpl-green bg-fpl-green/10 px-2 py-0.5 rounded-full">PEN</span>}
            {c.is_set_piece_taker && <span class="text-[11px] font-bold text-fpl-cyan bg-fpl-cyan/10 px-2 py-0.5 rounded-full">SET PIECE</span>}
          </div>
          {c.recommendation && (
            <div class="text-xs text-gray-300 mt-3 leading-relaxed">{c.recommendation}</div>
          )}
          </div>
        </a>
      </HeroCard>
    ))}
  </div>

  <!-- Mobile cards -->
  {rest.length > 0 && (
    <div class="md:hidden space-y-2">
      {rest.map((c, i) => (
        <a href={`/players/${slugify(c.player_id, c.first_name, c.second_name)}`} class="card p-4 block hover:bg-white/3 transition-colors">
          <div class="flex items-center gap-3">
            <span class="text-gray-400 text-xs w-5 text-right shrink-0">{i + 4}</span>
            <img src={c.shirt_url || ''} alt="" class="w-9 h-9 shrink-0 object-contain" width="110" height="140" loading="lazy" />
            <div class="flex-1 min-w-0">
              <div class="text-white font-medium truncate">{c.web_name} <span class="text-gray-400 text-xs">{c.team_short_name}</span></div>
              <div class="flex gap-2 mt-1">
                {c.is_home === true && <span class="text-[11px] font-bold text-emerald-400 bg-emerald-400/10 px-1.5 py-0.5 rounded">HOME</span>}
                {c.is_home === false && <span class="text-[11px] text-gray-400 bg-gray-400/10 px-1.5 py-0.5 rounded">AWAY</span>}
                {c.is_double_gw && <span class="text-[11px] font-bold text-fpl-pink bg-fpl-pink/10 px-1.5 py-0.5 rounded">DGW</span>}
                {c.is_penalty_taker && <span class="text-[11px] text-fpl-green bg-fpl-green/10 px-1.5 py-0.5 rounded">PEN</span>}
                {c.is_set_piece_taker && <span class="text-[11px] text-fpl-cyan bg-fpl-cyan/10 px-1.5 py-0.5 rounded">SP</span>}
              </div>
            </div>
            <div class="text-right shrink-0">
              <div class="text-fpl-green font-bold text-lg">{c.ceiling_score}</div>
              <div class="text-[11px] text-gray-400">ceiling</div>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-2 ml-8 mt-2 text-center">
            <div><div class="text-[11px] text-gray-400">Form 6GW</div><div class="text-white font-bold text-sm">{c.form_points}</div></div>
            <div><div class="text-[11px] text-gray-400">BPS Avg</div><div class="text-white font-bold text-sm">{c.bps_avg}</div></div>
          </div>
        </a>
      ))}
    </div>
  )}

  <!-- Desktop table -->
  {rest.length > 0 && (
    <div class="hidden md:block card overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-fpl-card">
          <tr class="text-left text-gray-400 border-b border-gray-700">
            <th class="py-2.5 px-3 font-medium">#</th>
            <th class="py-2.5 px-3 font-medium">Player</th>
            <th class="py-2.5 px-3 font-medium">Pos</th>
            <th class="py-2.5 px-3 text-right font-medium">Ceil 10GW</th>
            <th class="py-2.5 px-3 text-right font-medium">Form 6GW</th>
            <th class="py-2.5 px-3 text-right font-medium">BPS</th>
            <th class="py-2.5 px-3 text-center font-medium">Venue</th>
            <th class="py-2.5 px-3 text-center font-medium">Flags</th>
          </tr>
        </thead>
        <tbody>
          {rest.map((c, i) => (
            <tr class="border-b border-gray-800/40 hover:bg-white/3 transition-colors">
              <td class="py-2 px-3 text-gray-400">{i + 4}</td>
              <td class="py-2 px-3">
                <a href={`/players/${slugify(c.player_id, c.first_name, c.second_name)}`} class="flex items-center gap-2">
                  <img src={c.shirt_url || ''} alt="" class="w-7 h-7 shrink-0 object-contain" width="110" height="140" loading="lazy" />
                  <div>
                    <span class="link-cyan font-medium">{c.web_name}</span>
                    <span class="text-gray-400 text-xs ml-1">{c.team_short_name}</span>
                  </div>
                </a>
              </td>
              <td class="py-2 px-3"><PositionBadge position={c.position} /></td>
              <td class="py-2 px-3 text-right font-semibold text-fpl-green tabular-nums">{c.ceiling_score}</td>
              <td class="py-2 px-3 text-right tabular-nums">{c.form_points}</td>
              <td class="py-2 px-3 text-right tabular-nums">{c.bps_avg}</td>
              <td class="py-2 px-3 text-center">
                {c.is_home === true ? <span class="text-[11px] font-bold text-emerald-400">H</span> : c.is_home === false ? <span class="text-[11px] text-gray-400">A</span> : '-'}
              </td>
              <td class="py-2 px-3 text-center flex gap-1 justify-center">
                {c.is_double_gw && <span class="text-[11px] font-bold text-fpl-pink">DGW</span>}
                {c.is_penalty_taker && <span class="text-[11px] text-fpl-green">P</span>}
                {c.is_set_piece_taker && <span class="text-[11px] text-fpl-cyan">SP</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
  <script is:inline>
    if (typeof window.gtag === 'function') gtag('event', 'captain_pick_viewed');
  </script>
</Layout>
