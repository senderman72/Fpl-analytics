---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import HeroCard from '../../components/HeroCard.astro';
import PositionBadge from '../../components/PositionBadge.astro';
import { getBuyCandidates } from '../../api/decisions';
import { POSITIONS, formatCost } from '../../lib/types';
import { slugify } from '../../lib/seo';

const buys = await getBuyCandidates({ limit: 30 });
const top3 = buys.slice(0, 3);
const rest = buys.slice(3);
---

<Layout title="Transfer Planner" description="Top FPL transfer targets ranked by xGI, form, value, and fixture difficulty — find the best buys right now.">
  <Breadcrumb items={[{ label: 'Tools' }, { label: 'Transfers' }]} />
  <h1 class="page-title mb-1">Transfer Planner</h1>
  <p class="text-gray-400 text-sm mb-6">Based on last 6 GWs form + upcoming fixtures · Ranked by xGI/90 (40%) + PPM (30%) + Form (30%) - FDR penalty</p>

  <!-- Top 3 -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    {top3.map((b, i) => (
      <HeroCard rank={i + 1} accent={i === 0 ? 'border-fpl-green' : 'border-fpl-cyan'}>
        <a href={`/players/${slugify(b.player_id, b.first_name, b.second_name)}`} class="block">
          <div class="flex items-center gap-3 mb-3">
            <img src={b.shirt_url || ''} alt="" class="w-12 h-12 shrink-0 object-contain" width="110" height="140" loading="lazy" />
            <div>
              <div class="flex items-center gap-2">
                <span class="text-white font-bold text-lg">{b.web_name}</span>
                <PositionBadge position={b.position} />
              </div>
              <div class="text-xs text-gray-400">{b.team_short_name} · {formatCost(b.now_cost)}</div>
            </div>
          </div>
          <div class="grid grid-cols-4 gap-2">
            <div><div class="stat-label">xGI/90</div><div class="text-lg font-extrabold text-fpl-cyan">{b.xgi_per_90}</div></div>
            <div><div class="stat-label">PPM</div><div class="text-lg font-extrabold text-white">{b.ppm}</div></div>
            <div><div class="stat-label">Form (6 GW)</div><div class="text-lg font-extrabold text-fpl-green">{b.form_points}</div></div>
            <div><div class="stat-label">Predicted</div><div class="text-lg font-extrabold text-fpl-gold">{b.predicted_points ?? '-'}</div></div>
          </div>
          {b.recommendation && (
            <div class="mt-2 text-xs text-gray-300 leading-relaxed">{b.recommendation}</div>
          )}
        </a>
      </HeroCard>
    ))}
  </div>

  <!-- Mobile cards -->
  <div class="md:hidden space-y-2">
    {rest.map((b, i) => (
      <a href={`/players/${slugify(b.player_id, b.first_name, b.second_name)}`} class="card p-4 block hover:bg-white/3 transition-colors">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-gray-400 text-xs w-5 text-right shrink-0">{i + 4}</span>
          <img src={b.shirt_url || ''} alt="" class="w-9 h-9 shrink-0 object-contain" width="110" height="140" loading="lazy" />
          <div class="flex-1 min-w-0">
            <div class="text-white font-medium truncate">{b.web_name} <span class="text-gray-400 text-xs">{b.team_short_name}</span></div>
            <div class="text-xs text-gray-400">{formatCost(b.now_cost)} · <PositionBadge position={b.position} /></div>
          </div>
          <div class="text-right shrink-0">
            <div class="text-fpl-gold font-bold">{b.predicted_points ?? '-'}</div>
            <div class="text-[11px] text-gray-400">predicted</div>
          </div>
        </div>
        <div class="grid grid-cols-3 gap-2 ml-8 text-center">
          <div><div class="text-[11px] text-gray-400">Form 6GW</div><div class="text-fpl-green font-bold text-sm">{b.form_points}</div></div>
          <div><div class="text-[11px] text-gray-400">xGI/90</div><div class="text-white font-bold text-sm">{b.xgi_per_90}</div></div>
          <div><div class="text-[11px] text-gray-400">PPM</div><div class="text-white font-bold text-sm">{b.ppm}</div></div>
        </div>
      </a>
    ))}
  </div>

  <!-- Desktop table -->
  <div class="hidden md:block card overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-fpl-card">
          <tr class="text-left text-gray-400 border-b border-gray-700">
            <th class="py-2.5 px-3 font-medium">#</th>
            <th class="py-2.5 px-3 font-medium">Player</th>
            <th class="py-2.5 px-3 font-medium">Pos</th>
            <th class="py-2.5 px-3 text-right font-medium">Price</th>
            <th class="py-2.5 px-3 text-right font-medium">Form 6GW</th>
            <th class="py-2.5 px-3 text-right font-medium">Pts/G</th>
            <th class="py-2.5 px-3 text-right font-medium">xGI/90</th>
            <th class="py-2.5 px-3 text-right font-medium">PPM</th>
            <th class="py-2.5 px-3 text-right font-medium">Mins</th>
            <th class="py-2.5 px-3 text-right font-medium">FDR</th>
            <th class="py-2.5 px-3 text-right font-medium">Predicted</th>
          </tr>
        </thead>
        <tbody>
          {rest.map((b, i) => (
            <tr class="border-b border-gray-800/40 hover:bg-white/3 transition-colors">
              <td class="py-2 px-3 text-gray-400">{i + 4}</td>
              <td class="py-2 px-3">
                <a href={`/players/${slugify(b.player_id, b.first_name, b.second_name)}`} class="flex items-center gap-2">
                  <img src={b.shirt_url || ''} alt="" class="w-7 h-7 shrink-0 object-contain" width="110" height="140" loading="lazy" />
                  <div>
                    <span class="link-cyan font-medium">{b.web_name}</span>
                    <span class="text-gray-400 text-xs ml-1">{b.team_short_name}</span>
                  </div>
                </a>
              </td>
              <td class="py-2 px-3"><PositionBadge position={b.position} /></td>
              <td class="py-2 px-3 text-right tabular-nums">{formatCost(b.now_cost)}</td>
              <td class="py-2 px-3 text-right font-semibold text-fpl-green tabular-nums">{b.form_points}</td>
              <td class="py-2 px-3 text-right tabular-nums">{b.pts_per_game}</td>
              <td class="py-2 px-3 text-right tabular-nums">{b.xgi_per_90}</td>
              <td class="py-2 px-3 text-right tabular-nums">{b.ppm}</td>
              <td class="py-2 px-3 text-right tabular-nums">{Number(b.minutes_pct).toFixed(0)}%</td>
              <td class="py-2 px-3 text-right tabular-nums">{b.fdr_next_5 ?? '-'}</td>
              <td class="py-2 px-3 text-right">
                <span class="font-semibold text-fpl-gold tabular-nums">{b.predicted_points ?? '-'}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>
